# ============================================================
# FakeShield AI — .gitignore
# ============================================================

# ------------------------------------------------------------
# Python / FastAPI Backend
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pdb

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
.venv/
ENV/
.env
.env.*
!.env.example

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
*.cover
*.hypothesis/

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ------------------------------------------------------------
# Machine Learning Models & Weights
# ------------------------------------------------------------
*.h5
*.keras
*.ckpt
*.ckpt.*
*.pb
*.pt
*.pth
*.onnx
*.tflite
*.safetensors
backend/models/

# ------------------------------------------------------------
# Uploaded & Processed Media (backend)
# ------------------------------------------------------------
backend/uploads/
uploads/

# ------------------------------------------------------------
# Datasets (large binary assets — not for version control)
# ------------------------------------------------------------
image_dataset/
video_dataset/
dataset/
data/
datasets/

# ------------------------------------------------------------
# Node.js / React Frontend
# ------------------------------------------------------------
node_modules/
frontend/node_modules/

# Vite build output
frontend/dist/
frontend/.vite/
dist/
.vite/

# Dependency lock files (keep package-lock.json, ignore yarn)
yarn.lock
.yarn/
.pnp.*

# Env files (frontend)
frontend/.env
frontend/.env.*
!frontend/.env.example

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------
# Editor & IDE Files
# ------------------------------------------------------------
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json.example

# JetBrains / PyCharm / WebStorm
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs swaps
*.swp
*.swo
*~

# ------------------------------------------------------------
# OS Generated Files
# ------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory

# ------------------------------------------------------------
# Temporary & Scratch Files
# ------------------------------------------------------------
temp/
tmp/
*.tmp
*.bak
*.orig
*.rej
.cache/